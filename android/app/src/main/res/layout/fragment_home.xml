<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textColor="#000000"/>

        <!-- Three big spaces (Featured/Trending) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:src="@drawable/image"
                android:scaleType="centerCrop"
                android:background="#EEEEEE" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:src="@drawable/image_1_"
                android:scaleType="centerCrop"
                android:background="#EEEEEE" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_weight="1"
                android:src="@drawable/image_2_"
                android:scaleType="centerCrop"
                android:background="#EEEEEE" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="For You"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:textColor="#000000"/>

        <!-- Grid-like list of movies -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <ImageView
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:src="@drawable/image_3_"
                android:scaleType="centerCrop"
                android:background="#F5F5F5" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:src="@drawable/image_4_"
                android:scaleType="centerCrop"
                android:background="#F5F5F5" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:src="@drawable/image_5_"
                android:scaleType="centerCrop"
                android:background="#F5F5F5" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:src="@drawable/image_6_"
                android:scaleType="centerCrop"
                android:background="#F5F5F5" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:src="@drawable/image_7_"
                android:scaleType="centerCrop"
                android:background="#F5F5F5" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:src="@drawable/image_8_"
                android:scaleType="centerCrop"
                android:background="#F5F5F5" />

        </GridLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>